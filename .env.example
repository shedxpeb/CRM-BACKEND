# Application
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000
APP_NAME=PEB CRM

# Database
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/peb-crm?sslmode=disable"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/peb-crm?sslmode=disable"

# JWT / Cookies
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
COOKIE_SECRET=change-this-to-a-random-cookie-secret-at-least-32-chars
JWT_EXPIRES_IN=7d
JWT_ACCESS_EXPIRES_IN=30m
COOKIE_REFRESH_NAME=refreshToken
COOKIE_PATH=/
COOKIE_SAME_SITE=lax
COOKIE_SECURE=false
COOKIE_SIGNED=false

# Session
SESSION_ABSOLUTE_DAYS=1
SESSION_REMEMBER_ME_DAYS=30
SESSION_IDLE_MINUTES=120
SESSION_MULTI_DEVICE=false

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_MAX_RESENDS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_BCRYPT_ROUNDS=10
BCRYPT_ROUNDS=12
PASSWORD_HISTORY_SIZE=10

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=20
THROTTLE_AUTH_LIMIT=10

# Branding (used in email templates — no hardcoded company strings in code)
BRAND_COMPANY_NAME=PEB CRM
BRAND_COMPANY_LOGO=
BRAND_PRIMARY_COLOR=#0F766E
BRAND_SUPPORT_EMAIL=
BRAND_WEBSITE=http://localhost:3000
BRAND_ADDRESS=
BRAND_PHONE=
BRAND_SOCIAL_LINKEDIN=
BRAND_SOCIAL_TWITTER=
BRAND_SOCIAL_FACEBOOK=

# SMTP — Gmail / Zoho / Microsoft 365 / Custom (never hardcode in source)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=PEB CRM
SMTP_FROM_EMAIL=
SMTP_SECURE=false
SMTP_POOL=true
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100
SMTP_VERIFY_ON_BOOT=true

# Mail queue (in-process; falls back to direct send)
MAIL_QUEUE_ENABLED=true
MAIL_QUEUE_CONCURRENCY=2
