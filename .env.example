# Application
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000
APP_VERSION=0.0.1
API_VERSION=v1

# Database
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/peb-crm?sslmode=disable"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/peb-crm?sslmode=disable"

# JWT / Cookies
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
COOKIE_SECRET=change-this-to-a-random-cookie-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=30m
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/
COOKIE_REFRESH_NAME=refreshToken
COOKIE_SIGNED=false

# Sessions
SESSION_ABSOLUTE_DAYS=1
SESSION_REMEMBER_ME_DAYS=30
SESSION_IDLE_MINUTES=120
SESSION_MULTI_DEVICE=false
REFRESH_REUSE_GRACE_MS=10000

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
THROTTLE_AUTH_LIMIT=10

# Security
BCRYPT_ROUNDS=12
PASSWORD_HISTORY_SIZE=10

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10
OTP_MAX_ATTEMPTS=5
OTP_MAX_RESENDS=5
OTP_RESEND_COOLDOWN_SECONDS=60
OTP_BCRYPT_ROUNDS=10

# Mail provider:
#   smtp | gmail | zoho | microsoft365 | ses | sendgrid | mailgun
#   resend  — HTTPS API (port 443; works when hosts block SMTP)
#   auto    — try SMTP first, fall back to Resend if SMTP egress is blocked
# Switch providers via env only — no code changes required.
MAIL_PROVIDER=auto

# Resend HTTPS (required on Render free / when SMTP ports 25/465/587 are blocked)
# https://resend.com/api-keys — verify a domain, then set FROM to that domain.
RESEND_API_KEY=
RESEND_FROM_EMAIL=

# SMTP transport (used by smtp/gmail/zoho/microsoft365 and SMTP-compatible providers)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=
SMTP_SECURE=false
SMTP_POOL=true
SMTP_MAX_CONNECTIONS=5
SMTP_MAX_MESSAGES=100
SMTP_VERIFY_ON_BOOT=true
SMTP_REQUIRED=false
# 4 = force IPv4 (recommended on Render), 6 = IPv6 only, 0 = OS default
SMTP_IP_FAMILY=4
SMTP_CONNECTION_TIMEOUT_MS=10000
SMTP_GREETING_TIMEOUT_MS=10000
SMTP_SOCKET_TIMEOUT_MS=15000
SMTP_DNS_TIMEOUT_MS=5000

# Mail queue (in-process today; Redis/BullMQ later without API changes)
MAIL_QUEUE_ENABLED=true
MAIL_QUEUE_CONCURRENCY=2
MAIL_QUEUE_MAX_ATTEMPTS=5

# Health probe memory ceilings (MB) — /health only; deploy probes should use /live
HEALTH_HEAP_MB=1024
HEALTH_RSS_MB=1536

# Branding (dynamic — never hardcode in templates)
BRAND_COMPANY_NAME=
BRAND_COMPANY_LOGO=
BRAND_PRIMARY_COLOR=#0F766E
BRAND_SUPPORT_EMAIL=
BRAND_WEBSITE=
BRAND_ADDRESS=
BRAND_PHONE=
BRAND_SOCIAL_LINKEDIN=
BRAND_SOCIAL_TWITTER=
BRAND_SOCIAL_FACEBOOK=
