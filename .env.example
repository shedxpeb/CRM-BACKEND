# Development only — for production copy .env.production.example → .env.production
# Application
NODE_ENV=development
PORT=8000
FRONTEND_URL=http://localhost:3000
BACKEND_URL=http://localhost:8000

# Database
DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/peb-crm?sslmode=disable"
DIRECT_DATABASE_URL="postgresql://postgres:postgres@127.0.0.1:5432/peb-crm?sslmode=disable"

# JWT / Cookies
JWT_SECRET=change-this-to-a-random-secret-at-least-32-chars
COOKIE_SECRET=change-this-to-a-random-cookie-secret-at-least-32-chars
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECURE=false
COOKIE_SAME_SITE=lax
COOKIE_PATH=/
COOKIE_REFRESH_NAME=refreshToken

# OTP
OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10

# SMTP
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PEB CRM
MAIL_PROVIDER=smtp
MAIL_QUEUE_ENABLED=true

# Branding
BRAND_COMPANY_NAME=PEB CRM

# Rate limiting
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
THROTTLE_AUTH_LIMIT=10
