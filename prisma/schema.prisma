  fabrication_completed
  dispatch_started
  dispatch_completed
  installation_started
  installation_completed
  milestone_completed
  team_assigned
  task_assigned
  status_changed
  stage_changed
  document_uploaded
  note_added
  payment_received
  project_completed
  handover_completed
}

model Vendor {
  id                  String   @id @default(uuid())
  organizationId      String
  vendorNumber        Int      @unique @default(autoincrement())
  companyName         String
  gstNumber           String?
  panNumber           String?
  contactPerson       String
  email               String?
  phone               String
  address             String?
  city                String?
  state               String?
  pincode             String?
  country             String?  @default("India")
  bankDetails         Json?
  paymentTerms        String?
  creditLimit         Decimal?         @db.Decimal(14, 2)
  creditDays          Int?
  outstanding         Decimal          @default(0) @db.Decimal(14, 2)
  status              String   @default("Active")
  notes               String?
  attachments         String[]
  customFields        Json?
  createdById         String?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  isDeleted           Boolean  @default(false)
  deletedAt           DateTime?
  deletedById         String?
  organization        Organization @relation(fields: [organizationId], references: [id])
  purchaseOrders      PurchaseOrder[]

  @@index([organizationId])
  @@index([status])
  @@index([isDeleted])
  @@index([organizationId, status])
}

model PurchaseOrder {
  id                  String   @id @default(uuid())
  organizationId      String
  poNumber            String   @unique
  poNumberInt         Int      @unique @default(autoincrement())
  vendorId            String
  vendorName          String
  projectId           String?
  projectName         String?
  warehouseId         String?
  warehouseName       String?
  paymentTerms        String?
  expectedDeliveryDate DateTime?
  status              PurchaseOrderStatus @default(Draft)
  revision            Int      @default(0)
  revisionNote        String?
  currency            String   @default("INR")
  subtotal            Decimal          @default(0) @db.Decimal(14, 2)
  discount            Decimal          @default(0) @db.Decimal(14, 2)
  discountType        String?  @default("Amount")
  tax                 Decimal          @default(0) @db.Decimal(14, 2)
  freight             Decimal          @default(0) @db.Decimal(14, 2)
  packingCharges      Decimal          @default(0) @db.Decimal(14, 2)
  shippingCharges     Decimal          @default(0) @db.Decimal(14, 2)
  otherCharges        Decimal          @default(0) @db.Decimal(14, 2)
  roundOff            Decimal          @default(0) @db.Decimal(14, 2)
  grandTotal          Decimal          @default(0) @db.Decimal(14, 2)
  notes               String?
  terms               String?
  internalNotes       String?
  approvedById        String?
  approvedBy          String?
  approvedAt          DateTime?
  rejectedById        String?
  rejectedBy          String?
  rejectedAt          DateTime?
  rejectReason        String?
  sentToVendor        Boolean  @default(false)
  sentAt              DateTime?
  pdfGenerated        Boolean  @default(false)
  pdfUrl              String?
  customFields        Json?
  createdById         String?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  isDeleted           Boolean  @default(false)
  deletedAt           DateTime?
  deletedById         String?
  organization        Organization @relation(fields: [organizationId], references: [id])
  vendor              Vendor @relation(fields: [vendorId], references: [id])
  items               PurchaseOrderItem[]
  timeline            PurchaseOrderTimeline[]

  @@index([organizationId])
  @@index([vendorId])
  @@index([projectId])
  @@index([status])
  @@index([poNumber])
  @@index([createdAt])
  @@index([isDeleted])
  @@index([organizationId, status])
  @@index([organizationId, isDeleted])
}

model PurchaseOrderItem {
  id                  String   @id @default(uuid())
  organizationId      String
  purchaseOrderId     String
  itemMasterId        String?
  itemCode            String
  itemName            String
  description         String?
  quantity            Decimal          @db.Decimal(12, 3)
  unit                String
  rate                Decimal          @db.Decimal(14, 2)
  gstRate             Decimal?         @db.Decimal(5, 2)
  gstAmount           Decimal          @default(0) @db.Decimal(14, 2)
  discount            Decimal          @default(0) @db.Decimal(14, 2)
  discountType        String?  @default("Amount")
  total               Decimal          @db.Decimal(14, 2)
  hsnCode             String?
  receivedQuantity    Decimal          @default(0) @db.Decimal(12, 3)
  pendingQuantity     Decimal?         @db.Decimal(12, 3)
  receivedDate        DateTime?
  customFields        Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt
  purchaseOrder       PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([itemMasterId])
  @@index([organizationId])
}

model PurchaseOrderTimeline {
  id                  String   @id @default(uuid())
  organizationId      String
  purchaseOrderId     String
  action              String
  performedById       String?
  performedBy         String?
  metadata            Json?
  createdAt           DateTime @default(now())
  purchaseOrder       PurchaseOrder @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)

  @@index([purchaseOrderId])
  @@index([organizationId])
  @@index([createdAt])
}

enum PurchaseOrderStatus {
  Draft
  PendingApproval
  Approved
  Rejected
  Sent
  PartiallyReceived
  FullyReceived
  Cancelled
  Closed
}

// ─── Task Management ──────────────────────────────────────────────────────────

enum TaskStatus {
  Pending
  InProgress
  Blocked
  Review
  Completed
  Verified
  Rejected
  Closed
  Cancelled
  Reopened
}

enum TaskPriority {
  Low
  Medium
  High
  Critical
}

enum TaskCategory {
  General
  Office
  FieldWork
  Maintenance
  Installation
  Inspection
  Documentation
  Meeting
  Training
  Other
}

enum LinkedModule {
  Leads
  Customers
  Projects
  Estimates
  Proposals
  Quotations
  Invoices
  Inventory
  Purchases
  Finance
  Documents
  General
}

enum SalaryAdjustmentType {
  Credit
  Deduction
  Advance
  Bonus
  Penalty
}

enum SalaryAdjustmentStatus {
  Pending
  Approved
  Rejected
  Processed
}

model Task {
  id                  String          @id @default(uuid())
  organizationId      String
  taskId              Int             @unique @default(autoincrement())
  title               String
  description         String?

  // Assignment
  assignedUserId      String
  assignedUserName    String
  createdById         String
  createdByName       String

  // Dates
  startDate           DateTime?
  dueDate             DateTime
  reminderDate        DateTime?
  completedAt         DateTime?
  verifiedAt          DateTime?
  closedAt            DateTime?

  // Status & Priority
  status              TaskStatus      @default(Pending)
  priority            TaskPriority    @default(Medium)
  category            TaskCategory?

  // Progress & Time
  progress            Int             @default(0)
  estimatedHours      Float?
  timeSpent           Float?

  // Cross-module links
  linkedModule        LinkedModule?
  linkedRecordId      String?
  linkedRecordName    String?
  projectId           String?
  leadId              String?
  customerId          String?
  documentId          String?

  // Payment
  incentiveValue      Float           @default(0)
  isPaymentEditable   Boolean         @default(false)

  // Completion
  completionNotes     String?
  completionProof     Json?
  beforeImages        String[]
  afterImages         String[]

  // Verification
  verifiedBy          String?
  verifiedByName      String?
  verificationNotes   String?

  // Notes
  notes               String?
  internalNotes       String?

  // Tags
  tags                String[]

  // Metadata
  createdById_field   String?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @updatedAt
  isDeleted           Boolean         @default(false)
  deletedAt           DateTime?
  deletedById         String?

  // Relations
  organization        Organization    @relation(fields: [organizationId], references: [id])
  checklist           TaskChecklist[]
  comments            TaskComment[]
  attachments         TaskAttachment[]
  dependencies        TaskDependency[]
  activities          TaskActivityLog[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, priority])
  @@index([assignedUserId])
  @@index([createdById])
  @@index([status])
  @@index([dueDate])
  @@index([isDeleted])
  @@index([organizationId, isDeleted])
}

model TaskChecklist {
  id             String   @id @default(uuid())
  taskId         String
  text           String
  completed      Boolean  @default(false)
  completedAt    DateTime?
  completedBy    String?
  order          Int      @default(0)
  createdAt      DateTime @default(now())
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskComment {
  id             String   @id @default(uuid())
  taskId         String
  content        String
  authorId       String
  authorName     String
  isInternal     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false)
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, createdAt])
}

model TaskAttachment {
  id             String   @id @default(uuid())
  taskId         String
  fileName       String
  fileType       String
  fileSize       Int
  fileUrl        String
  uploadedBy     String
  uploadedByName String
  description    String?
  createdAt      DateTime @default(now())
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
}

model TaskDependency {
  id             String   @id @default(uuid())
  taskId         String
  dependsOnTaskId String
  relationship   String   @default("Depends On")
  createdAt      DateTime @default(now())
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([dependsOnTaskId])
}

model TaskActivityLog {
  id             String   @id @default(uuid())
  taskId         String
  activityType   String
  description    String
  performedBy    String
  performedByName String
  metadata       Json?
  createdAt      DateTime @default(now())
  task           Task     @relation(fields: [taskId], references: [id], onDelete: Cascade)

  @@index([taskId])
  @@index([taskId, createdAt])
}

model SalaryAdjustment {
  id              String                @id @default(uuid())
  organizationId  String
  employeeId      String
  employeeName    String
  type            SalaryAdjustmentType
  amount          Float
  description     String
  reason          String?
  referenceType   String?
  referenceId     String?
  referenceName   String?
  status          SalaryAdjustmentStatus @default(Pending)
  approvedBy      String?
  approvedByName  String?
  approvedAt      DateTime?
  processedAt     DateTime?
  processedBy     String?
  notes           String?
  createdById     String
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  isDeleted       Boolean               @default(false)
  organization    Organization          @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
  @@index([organizationId, employeeId])
  @@index([organizationId, status])
  @@index([employeeId])
  @@index([isDeleted])
}
