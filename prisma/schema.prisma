generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_DATABASE_URL")
}

model Organization {
  id               String             @id @default(uuid())
  name             String
  email            String?            @unique
  mobile           String?
  address          String?
  city             String?
  state            String?
  country          String?            @default("India")
  pincode          String?
  gstNumber        String?
  panNumber        String?
  website          String?
  status           OrganizationStatus @default(Active)
  maxUsers         Int                @default(25)
  maxStorageGb     Int                @default(10)
  subscriptionTier String             @default("free")
  settings         Json?
  createdById      String?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  isDeleted        Boolean            @default(false)
  deletedAt        DateTime?
  customers        Customer[]
  leads            Lead[]
  projects         Project[]
  users            User[]
  itemMasters      ItemMaster[]
  itemVariants     ItemVariant[]
  itemBundles      ItemBundle[]
  warehouses       Warehouse[]
  suppliers        Supplier[]
  inventoryItems   InventoryItem[]
  stockMovements   StockMovement[]
  inventoryCategories InventoryCategory[]
  vendors          Vendor[]
  purchaseOrders   PurchaseOrder[]
  tasks            Task[]
  salaryAdjustments SalaryAdjustment[]

  @@index([status])
  @@index([email])
  @@index([name])
  @@index([isDeleted])
}

model User {
  id                  String           @id @default(uuid())
  email               String           @unique
  password            String
  isActive            Boolean          @default(false)
  isVerified          Boolean          @default(false)
  otp                 String?
  otpExpiry           DateTime?
  otpAttempts         Int              @default(0)
  role                UserRole         @default(OWNER)
  organizationType    OrganizationType @default(COMPANY)
  createdAt           DateTime         @default(now())
  updatedAt           DateTime         @updatedAt
  avatar              String?
  department          String?
  designation         String?
  failedLoginAttempts Int              @default(0)
  isLocked            Boolean          @default(false)
  lastLogin           DateTime?
  lockedUntil         DateTime?
  mobile              String?
  name                String?
  organizationId      String?
  passwordHistory     Json?
  passwordVersion     Int              @default(1)
  refreshTokens       RefreshToken[]
  sessions            Session[]
  organization        Organization?    @relation(fields: [organizationId], references: [id])

  @@index([email])
  @@index([role])
  @@index([organizationId])
  @@index([organizationId, role])
}

model Session {
  id             String         @id @default(uuid())
  userId         String
  organizationId String?
  token          String         @unique
  refreshToken   String?
  device         String?
  browser        String?
  os             String?
  ipAddress      String?
  userAgent      String?
  loginAt        DateTime       @default(now())
  lastActivity   DateTime       @default(now())
  expiresAt      DateTime
  idleExpiresAt  DateTime
  isRevoked      Boolean        @default(false)
  revokedAt      DateTime?
  isRememberMe   Boolean        @default(false)
  refreshTokens  RefreshToken[]
  user           User           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@index([userId, isRevoked])
  @@index([expiresAt])
}

model RefreshToken {
  id                  String    @id @default(uuid())
  tokenHash           String    @unique
  sessionId           String
  userId              String
  organizationId      String?
  expiresAt           DateTime
  isRevoked           Boolean   @default(false)
  revokedAt           DateTime?
  replacedByTokenHash String?
  session             Session   @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([tokenHash])
  @@index([sessionId])
  @@index([userId])
}

model LoginAttempt {
  id             String    @id @default(uuid())
  email          String
  organizationId String?
  ipAddress      String?
  userAgent      String?
  success        Boolean
  failureReason  String?
  lockedUntil    DateTime?
  createdAt      DateTime  @default(now())

  @@index([email])
  @@index([createdAt])
  @@index([email, createdAt])
}

/// Hashed OTP challenges only — never plaintext OTP, never email HTML/text/subject.
/// Rows are hard-deleted immediately after successful verification, expiry, or invalidation.
model OtpChallenge {
  id          String     @id @default(uuid())
  email       String
  userId      String?
  purpose     OtpPurpose
  codeHash    String
  expiresAt   DateTime
  attempts    Int        @default(0)
  maxAttempts Int
  resendCount Int        @default(0)
  maxResends  Int
  /// Legacy soft-consume marker; runtime prefers hard-delete after use/expiry.
  consumedAt  DateTime?
  lastSentAt  DateTime   @default(now())
  /// Operational metadata only — never OTP, HTML, subject, or secrets.
  metadata    Json?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@index([email, purpose, consumedAt])
  @@index([userId, purpose])
  @@index([expiresAt])
}

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String?
  userId         String?
  sessionId      String?
  action         String
  resource       String?
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  userAgent      String?
  createdAt      DateTime @default(now())

  @@index([organizationId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model Role {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  permissions    String[]
  isSystem       Boolean  @default(false)
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, name])
  @@index([organizationId])
}

model Customer {
  id                  String         @id @default(uuid())
  organizationId      String
  customerId          Int            @unique @default(autoincrement())
  customerName        String
  companyName         String
  mobile              String
  alternateMobile     String?
  email               String
  gstNumber           String?
  panNumber           String?
  industry            Industry?
  businessType        String?
  website             String?
  address             String
  city                String
  state               String
  country             String?        @default("India")
  pincode             String?
  assignedEmployee    String?
  assignedEmployeeId  String?
  source              String         @default("Website")
  status              CustomerStatus @default(Prospect)
  notes               String?
  attachments         String[]
  customerSince       DateTime       @default(now())
  leadId              String?
  convertedFromLeadId String?
  createdById         String?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt
  isDeleted           Boolean        @default(false)
  deletedAt           DateTime?
  deletedById         String?
  customFields        Json?
  organization        Organization   @relation(fields: [organizationId], references: [id])

  @@index([leadId])
  @@index([status])
  @@index([createdAt])
  @@index([mobile])
  @@index([companyName])
  @@index([isDeleted])
  @@index([organizationId])
  @@index([organizationId, status])
}

model Project {
  id                      String              @id @default(uuid())
  organizationId          String
  projectId               Int                 @unique @default(autoincrement())
  projectCode             String?
  projectName             String
  customerId              String
  customerName            String
  leadId                  String?
  projectType             String
  value                   Decimal?           @db.Decimal(14, 2)
  budget                  Decimal?           @db.Decimal(14, 2)
  location                String
  city                    String
  state                   String
  pincode                 String?
  startDate               DateTime?
  endDate                 DateTime?
  priority                ProjectPriority
  projectManager          String?
  projectManagerId        String?
  structureType           String
  width                   Decimal?           @db.Decimal(12, 3)
  length                  Decimal?           @db.Decimal(12, 3)
  height                  Decimal?           @db.Decimal(12, 3)
  baySpacing              Decimal?           @db.Decimal(12, 3)
  roofType                String
  craneSystem             String
  mezzanine               Boolean             @default(false)
  wallType                String
  insulation              Boolean             @default(false)
  coveredArea             Decimal?           @db.Decimal(12, 3)
  totalWeight             Decimal?           @db.Decimal(12, 3)
  status                  String              @default("Lead")
  stage                   ProjectStage?
  progress                Int                 @default(0)
  designProgress          Int                 @default(0)
  procurementProgress     Int                 @default(0)
  fabricationProgress     Int                 @default(0)
  installationProgress    Int                 @default(0)
  healthStatus            String              @default("Healthy")
  timelineHealth          String              @default("Healthy")
  budgetHealth            String              @default("Healthy")
  materialHealth          String              @default("Healthy")
  resourceHealth          String              @default("Healthy")
  materialCost            Decimal?           @db.Decimal(14, 2)
  procurementCost         Decimal?           @db.Decimal(14, 2)
  fabricationCost         Decimal?           @db.Decimal(14, 2)
  installationCost        Decimal?           @db.Decimal(14, 2)
  profitMargin            Decimal?           @db.Decimal(5, 2)
  boqId                   String?
  designId                String?
  estimateId              String?
  proposalId              String?
  quotationId             String?
  invoiceIds              String[]
  inventoryReservationIds String[]
  reservedItems           String[]
  consumedItems           String[]
  customFields            Json?
  createdById             String?
  createdBy               String?
  updatedBy               String?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
  isDeleted               Boolean             @default(false)
  deletedAt               DateTime?
  deletedById             String?
  organization            Organization        @relation(fields: [organizationId], references: [id])
  milestones              ProjectMilestone[]
  teamMembers             ProjectTeamMember[]

  @@index([status])
  @@index([stage])
  @@index([priority])
  @@index([createdAt])
  @@index([customerId])
  @@index([customerName])
  @@index([projectManagerId])
  @@index([isDeleted])
  @@index([projectCode])
  @@index([organizationId])
  @@index([organizationId, status])
}

model ProjectMilestone {
  id          String                 @id @default(uuid())
  projectId   String
  name        String
  plannedDate DateTime?
  actualDate  DateTime?
  status      ProjectMilestoneStatus @default(Pending)
  delay       Int?
  project     Project                @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
}

model ProjectTeamMember {
  id           String   @id @default(uuid())
  projectId    String
  employeeId   String
  name         String?
  role         String
  assignedDate DateTime @default(now())
  workload     Int?
  project      Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([employeeId])
}

model ProjectActivity {
  id          String              @id @default(uuid())
  projectId   String
  type        ProjectActivityType
  description String
  performedBy String?
  performedAt DateTime            @default(now())
  metadata    Json?

  @@index([projectId])
  @@index([projectId, performedAt])
}

model ProjectTask {
  id             String            @id @default(uuid())
  projectId      String
  title          String
  description    String?
  assignedTo     String
  assignedToName String?
  dueDate        DateTime?
  priority       ProjectPriority
  status         ProjectTaskStatus @default(Pending)
  dependencies   String[]
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  @@index([projectId])
  @@index([projectId, status])
  @@index([assignedTo])
}

model Lead {
  id                  String              @id @default(uuid())
  customerName        String
  companyName         String
  mobile              String
  email               String
  city                String?
  projectTitle        String
  projectType         ProjectType
  structureType       StructureType
  source              LeadSource
  priority            LeadPriority
  status              LeadStatus          @default(New)
  lastFollowUp        DateTime?
  nextFollowUpDate    DateTime?
  updatedAt           DateTime            @updatedAt
  remarks             String?
  assignedToId        String?
  createdAt           DateTime            @default(now())
  createdById         String
  isConverted         Boolean             @default(false)
  leadNumber          Int                 @unique @default(autoincrement())
  deletedAt           DateTime?
  deletedById         String?
  isDeleted           Boolean             @default(false)
  alternateMobile     String?
  assignedTo          String?
  attachments         String[]
  baySpacing          Decimal?           @db.Decimal(12, 3)
  convertedDate       DateTime?
  craneCapacity       Decimal?           @db.Decimal(12, 3)
  craneRequired       Boolean?            @default(false)
  createdBy           String?
  customFields        Json?
  customerId          String?
  customerNotes       String?
  gstNumber           String?
  height              Decimal?           @db.Decimal(12, 3)
  insulationRequired  Boolean?            @default(false)
  insulationThickness Decimal?           @db.Decimal(12, 3)
  insulationType      String?
  length              Decimal?           @db.Decimal(12, 3)
  mapCoordinates      String?
  mezzanine           Boolean?            @default(false)
  mezzanineArea       Decimal?           @db.Decimal(12, 3)
  mezzanineLoad       Decimal?           @db.Decimal(12, 3)
  pincode             String?
  score               Int?
  siteAddress         String?
  siteLocation        String?
  soilNotes           String?
  specialRequirement  String?
  state               String?
  updatedBy           String?
  width               Decimal?           @db.Decimal(12, 3)
  addressLine1        String?
  addressLine2        String?
  annualRevenue       Decimal?           @db.Decimal(14, 2)
  area                String?
  businessType        BusinessType?
  companyLogo         String?
  companySize         String?
  country             String?             @default("India")
  designation         String?
  employeeCount       Int?
  facebook            String?
  industry            Industry?
  instagram           String?
  linkedin            String?
  organizationId      String
  panNumber           String?
  profileImage        String?
  tags                String[]
  website             String?
  materialPreference  MaterialPreference?
  roofType            RoofType?
  wallType            WallType?
  organization        Organization        @relation(fields: [organizationId], references: [id])

  @@index([status])
  @@index([priority])
  @@index([createdAt])
  @@index([nextFollowUpDate])
  @@index([mobile])
  @@index([companyName])
  @@index([createdById])
  @@index([assignedToId])
  @@index([isDeleted])
  @@index([organizationId])
  @@index([organizationId, status])
}

model StatusPipeline {
  id                 String   @id @default(uuid())
  organizationId     String
  entityType         String
  status             String
  order              Int
  label              String?
  color              String?
  allowedTransitions String[]
  isInitial          Boolean  @default(false)
  isFinal            Boolean  @default(false)
  isActive           Boolean  @default(true)
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt

  @@unique([organizationId, entityType, status])
  @@index([organizationId, entityType, order])
  @@index([organizationId, entityType])
}

model StatusHistory {
  id             String   @id @default(uuid())
  organizationId String
  entityType     String
  entityId       String
  fromStatus     String?
  toStatus       String
  changedById    String?
  changedAt      DateTime @default(now())
  reason         String?
  metadata       Json?

  @@index([entityType, entityId, changedAt])
  @@index([entityType, entityId])
  @@index([organizationId, entityType, changedAt])
}

model Comment {
  id             String   @id @default(uuid())
  organizationId String
  entityType     String
  entityId       String
  content        String
  authorId       String
  parentId       String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  isDeleted      Boolean  @default(false)

  @@index([entityType, entityId, createdAt])
  @@index([entityType, entityId])
  @@index([authorId])
}

model Attachment {
  id             String   @id @default(uuid())
  organizationId String
  entityType     String
  entityId       String
  fileName       String
  originalName   String
  mimeType       String
  size           Int
  url            String
  category       String?
  uploadedById   String?
  createdAt      DateTime @default(now())
  isDeleted      Boolean  @default(false)

  @@index([entityType, entityId])
  @@index([entityType, entityId, createdAt])
}

model ApprovalRequest {
  id             String    @id @default(uuid())
  organizationId String
  entityType     String
  entityId       String
  level          Int       @default(1)
  requestedById  String
  approverId     String
  status         String    @default("Pending")
  comment        String?
  requestedAt    DateTime  @default(now())
  respondedAt    DateTime?
  escalatedAt    DateTime?
  metadata       Json?

  @@index([entityType, entityId, level])
  @@index([entityType, entityId])
  @@index([approverId, status])
  @@index([organizationId])
}

model Notification {
  id             String    @id @default(uuid())
  organizationId String
  userId         String
  title          String
  message        String
  type           String    @default("info")
  entityType     String?
  entityId       String?
  isRead         Boolean   @default(false)
  readAt         DateTime?
  createdAt      DateTime  @default(now())

  @@index([userId, isRead])
  @@index([userId, createdAt])
  @@index([organizationId])
}

model BusinessEvent {
  id             String   @id @default(uuid())
  organizationId String
  entityType     String
  entityId       String
  eventType      String
  data           Json?
  createdById    String?
  createdAt      DateTime @default(now())

  @@index([organizationId, entityType, entityId, createdAt])
  @@index([organizationId, entityType, eventType])
  @@index([entityType, entityId])
}

model EventRule {
  id             String   @id @default(uuid())
  organizationId String
  entityType     String
  eventType      String
  fromStatus     String?
  toStatus       String
  fromStage      String?
  toStage        String?
  condition      Json?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, entityType, eventType, fromStatus])
  @@index([organizationId, entityType, isActive])
}

model NumberSequence {
  id             String   @id @default(uuid())
  organizationId String
  entityName     String
  prefix         String
  lastValue      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([organizationId, entityName])
  @@index([organizationId])
}

enum LeadStatus {
  New
  Contacted
  DesignPending
  BOQPending
  EstimateSent
  ProposalSent
  Negotiation
  Approved
  Rejected
  Converted
}

enum ProjectType {
  Factory
  Warehouse
  IndustrialShed
  Commercial
  Residential
  ColdStorage
  Other
}

enum StructureType {
  PEB
  SteelStructure
  Hybrid
  Other
}

enum RoofType {
  MetalSheet
  DeckSheet
  SandwichPanel
  Other
}

enum WallType {
  MetalSheet
  BrickWall
  SandwichPanel
  Other
}

enum MaterialPreference {
  Standard
  Premium
  Economy
}

enum LeadSource {
  Website
  Referral
  ColdCall
  Email
  SocialMedia
  TradeShow
  Advertisement
  Other
}

enum LeadPriority {
  Low
  Medium
  High
  Urgent
}

enum CustomerStatus {
  Active
  Inactive
  Prospect
  Converted
  Churned
  Archived
}

enum Industry {
  Construction
  Manufacturing
  Technology
  Healthcare
  Hospitality
  Retail
  Education
  Finance
  RealEstate
  Infrastructure
  Energy
  Mining
  Agriculture
  Transportation
  Logistics
  Commercial
  Other
}

enum BusinessType {
  SoleProprietorship
  Partnership
  PrivateLimited
  PublicLimited
  LLP
  Government
  NonProfit
  Other
}

enum UserRole {
  SUPER_ADMIN
  OWNER
  EMPLOYEE
  ADMIN
}

enum OrganizationType {
  SYSTEM
  COMPANY
}

enum OrganizationStatus {
  Active
  Inactive
  Suspended
}

enum OtpPurpose {
  REGISTRATION
  FORGOT_PASSWORD
  EMAIL_VERIFICATION
  CHANGE_EMAIL
  TWO_FACTOR
  ORGANIZATION_INVITE
}

enum ProjectStage {
  Design
  BOQ
  Procurement
  Fabrication
  Dispatch
  Installation
  Handover
}

enum ProjectPriority {
  Low
  Medium
  High
  Urgent
}

enum ProjectTaskStatus {
  Pending
  InProgress
  Completed
  Overdue
}

enum ProjectMilestoneStatus {
  Pending
  InProgress
  Completed
  Delayed
}

model ItemMaster {
  id                  String      @id @default(uuid())
  organizationId      String
  itemNumber          Int         @unique @default(autoincrement())
  sku                 String
  itemCode            String
  itemName            String
  category            String
  subCategory         String?
  categoryId          String?
  subcategoryId       String?
  itemTypeId          String?
  brand               String?
  grade               String?
  specification       String?
  hsnCode             String?
  unit                String
  weight              Decimal?           @db.Decimal(12, 3)
  defaultRate         Decimal?           @db.Decimal(14, 2)
  gstRate             Decimal?           @db.Decimal(5, 2)
  taxType             String?
  technicalDescription String?
  datasheetUrl        String?
  productImageUrl     String?
  status              String      @default("Active")
  tags                String[]
  manufacturer        String?
  countryOfOrigin     String?
  description         String?
  standardDimensions  Json?
  currency            String?     @default("INR")
  images              String[]
  preferredSupplierId String?
  preferredSupplier   String?
  inventoryItemId     String?
  notes               String?
  internalNotes       String?
  itemTypeClass       String?
  materialGrade       String?
  isStructural        Boolean     @default(false)
  isCladding          Boolean     @default(false)
  isAccessory         Boolean     @default(false)
  isService           Boolean     @default(false)
  thickness           Decimal?           @db.Decimal(12, 3)
  length              Decimal?           @db.Decimal(12, 3)
  width               Decimal?           @db.Decimal(12, 3)
  customFields        Json?
  createdById         String?
  createdBy           String?
  updatedBy           String?
  createdAt           DateTime    @default(now())
  updatedAt           DateTime    @updatedAt
  isDeleted           Boolean     @default(false)
  deletedAt           DateTime?
  deletedById         String?
  organization        Organization @relation(fields: [organizationId], references: [id])
  variants            ItemVariant[]
  bundles             ItemBundleItem[]
  inventoryItems      InventoryItem[]

  @@unique([organizationId, sku])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([organizationId, category])
  @@index([itemCode])
  @@index([isDeleted])
}

model ItemVariant {
  id             String    @id @default(uuid())
  organizationId String
  itemMasterId   String
  variantName    String
  variantCode    String
  specifications String?
  standardWeight Decimal?           @db.Decimal(12, 3)
  dimensions     Json?
  defaultRate    Decimal?           @db.Decimal(14, 2)
  status         String    @default("Active")
  customFields   Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])
  itemMaster     ItemMaster @relation(fields: [itemMasterId], references: [id], onDelete: Cascade)

  @@index([itemMasterId])
  @@index([organizationId])
}

model ItemBundle {
  id                  String    @id @default(uuid())
  organizationId      String
  bundleCode          String
  bundleName          String
  description         String?
  bundleRate          Decimal?           @db.Decimal(14, 2)
  discountPercentage  Decimal?           @db.Decimal(5, 2)
  status              String    @default("Active")
  customFields        Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
  isDeleted           Boolean   @default(false)
  organization        Organization @relation(fields: [organizationId], references: [id])
  items               ItemBundleItem[]

  @@index([organizationId])
  @@index([isDeleted])
}

model ItemBundleItem {
  id             String     @id @default(uuid())
  organizationId String
  bundleId       String?
  itemMasterId   String
  quantity       Int        @default(1)
  unit           String?
  rate           Decimal?           @db.Decimal(14, 2)
  itemMaster     ItemMaster @relation(fields: [itemMasterId], references: [id])
  bundle         ItemBundle? @relation(fields: [bundleId], references: [id], onDelete: Cascade)

  @@index([bundleId])
  @@index([itemMasterId])
}

model Warehouse {
  id               String    @id @default(uuid())
  organizationId   String
  warehouseCode    String
  name             String
  location         String
  address          String?
  manager          String?
  contactNumber    String?
  capacity         Decimal?           @db.Decimal(12, 3)
  currentOccupancy Decimal?           @db.Decimal(12, 3)    @default(0)
  status           String    @default("Active")
  notes            String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)
  organization     Organization @relation(fields: [organizationId], references: [id])
  inventoryItems   InventoryItem[]

  @@unique([organizationId, warehouseCode])
  @@index([organizationId])
  @@index([isDeleted])
}

model Supplier {
  id               String    @id @default(uuid())
  organizationId   String
  name             String
  gstNumber        String?
  contactPerson    String
  mobile           String
  email            String?
  address          String?
  city             String?
  state            String?
  pincode          String?
  gstRegistered    Boolean   @default(false)
  suppliedMaterials String[]
  leadTime         Int?
  rating           Decimal?           @db.Decimal(5, 2)
  notes            String?
  status           String    @default("Active")
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  isDeleted        Boolean   @default(false)
  organization     Organization @relation(fields: [organizationId], references: [id])
  inventoryItems   InventoryItem[]

  @@index([organizationId])
  @@index([isDeleted])
}

model InventoryCategory {
  id             String    @id @default(uuid())
  organizationId String
  name           String
  parentId       String?
  description    String?
  itemCount      Int       @default(0)
  sortOrder      Int       @default(0)
  isActive       Boolean   @default(true)
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId])
}

model InventoryItem {
  id               String         @id @default(uuid())
  organizationId   String
  itemNumber       Int            @unique @default(autoincrement())
  itemCode         String
  itemMasterId     String?
  itemName         String
  unit             String
  currentStock     Decimal          @default(0) @db.Decimal(12, 3)
  reservedStock    Decimal          @default(0) @db.Decimal(12, 3)
  issuedStock      Decimal          @default(0) @db.Decimal(12, 3)
  minimumStock     Decimal          @default(0) @db.Decimal(12, 3)
  reorderLevel     Decimal          @default(0) @db.Decimal(12, 3)
  safetyStock      Decimal          @default(0) @db.Decimal(12, 3)
  purchaseRate     Decimal?         @db.Decimal(14, 2)
  totalValue       Decimal          @default(0) @db.Decimal(14, 2)
  warehouseId      String?
  warehouseName    String?
  binLocation      String?
  reorderQuantity  Decimal?         @db.Decimal(12, 3)
  incomingStock    Decimal          @default(0) @db.Decimal(12, 3)
  outgoingStock    Decimal          @default(0) @db.Decimal(12, 3)
  category         String?
  brand            String?
  itemTypeClass    String?
  status           String         @default("In Stock")
  lastUpdated      DateTime       @default(now())
  customFields     Json?
  tags             String[]
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  isDeleted        Boolean        @default(false)
  deletedAt        DateTime?
  deletedById      String?
  organization     Organization   @relation(fields: [organizationId], references: [id])
  itemMaster       ItemMaster?    @relation(fields: [itemMasterId], references: [id])
  warehouse        Warehouse?     @relation(fields: [warehouseId], references: [id])
  supplier         Supplier?      @relation(fields: [supplierId], references: [id])
  supplierId       String?
  movements        StockMovement[]

  @@unique([organizationId, itemCode])
  @@index([organizationId])
  @@index([organizationId, status])
  @@index([itemCode])
  @@index([itemMasterId])
  @@index([warehouseId])
  @@index([isDeleted])
}

model StockMovement {
  id               String    @id @default(uuid())
  organizationId   String
  movementNumber   String
  inventoryItemId  String
  itemName         String
  type             String
  quantity         Decimal          @db.Decimal(12, 3)
  warehouseId      String?
  warehouseName    String?
  fromWarehouseId  String?
  toWarehouseId    String?
  referenceNumber  String?
  referenceType    String?
  performedBy      String
  remarks          String?
  date             DateTime  @default(now())
  createdAt        DateTime  @default(now())
  organization     Organization @relation(fields: [organizationId], references: [id])
  inventoryItem    InventoryItem @relation(fields: [inventoryItemId], references: [id])

  @@index([organizationId])
  @@index([inventoryItemId])
  @@index([type])
  @@index([date])
}

enum ProjectActivityType {
  project_created
  project_updated
  design_started
  design_completed
  design_uploaded
  boq_created
  boq_updated
  procurement_started
  material_reserved
  purchase_request_created
