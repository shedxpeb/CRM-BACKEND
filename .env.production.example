# Copy to .env.production (or set equivalent CI/CD variables).
# Production must not use development secrets or localhost URLs.

NODE_ENV=production
PORT=8000
APP_VERSION=1.0.0
API_VERSION=v1
FRONTEND_URL=https://app.your-domain.com

DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/peb-crm?sslmode=require
DIRECT_DATABASE_URL=postgresql://USER:PASSWORD@HOST:5432/peb-crm?sslmode=require

JWT_SECRET=change-me-to-a-random-secret-at-least-32-chars
COOKIE_SECRET=change-me-to-a-random-cookie-secret-32plus
JWT_ACCESS_EXPIRES_IN=30m
JWT_REFRESH_EXPIRES_IN=30d
COOKIE_SECURE=true
COOKIE_SAME_SITE=lax
COOKIE_PATH=/
COOKIE_REFRESH_NAME=refreshToken

OTP_LENGTH=6
OTP_EXPIRY_MINUTES=10

SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=PEB CRM
SMTP_SECURE=false
SMTP_VERIFY_ON_BOOT=true
MAIL_PROVIDER=smtp
MAIL_QUEUE_ENABLED=true

BRAND_COMPANY_NAME=PEB CRM
THROTTLE_TTL_MS=60000
THROTTLE_LIMIT=60
THROTTLE_AUTH_LIMIT=10
